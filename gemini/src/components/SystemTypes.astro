---
import type { Service } from '~/lib/types';
import Section from '~/components/Section.astro';
interface Props { svc: Service }
const { svc } = Astro.props;
---
<Section id="systems">
  <div class="st__lead">
    <p class="kicker">Systems we install</p>
    <h2>{svc.systemTypesHeadline}</h2>
    <p class="lede">Each agent below is a system Gemini AMPM designs, installs and commissions directly — by directly-employed BAFE-registered engineers, with no sub-contracted labour.</p>
  </div>

  <div class="st__grid">
    {svc.systemTypes.map((s) => (
      <article class="st__card" id={s.anchorSlug}>
        {s.manufacturer && <div class="st__mfr">{s.manufacturer}</div>}
        <h3 class="st__h">{s.h3}</h3>
        <p class="st__bestfor"><strong>Best for:</strong> {s.bestForLine}</p>
        <p class="st__body">{s.bodyCopy}</p>
      </article>
    ))}
  </div>

  <div class="st__softcta">
    <p>{svc.closingSoftCTA}</p>
    <a class="btn btn--line btn--sm" href="#consult">Book a consultation →</a>
  </div>
</Section>

<style>
  .st__lead { max-width: 780px; margin-bottom: var(--s-7); }
  .st__grid {
    display: grid; gap: var(--s-5);
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  }
  .st__card {
    background: var(--bg-elev);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: var(--s-6);
    scroll-margin-top: 80px;
  }
  .st__mfr {
    display: inline-block;
    font-size: var(--t-kicker);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: var(--s-3);
  }
  .st__h { margin: 0 0 var(--s-4); font-size: var(--t-display-s); }
  .st__bestfor { color: var(--text-soft); font-size: var(--t-body-s); margin-bottom: var(--s-3); }
  .st__body { color: var(--text); }

  .st__softcta {
    margin-top: var(--s-7);
    padding: var(--s-6);
    background: var(--accent-soft);
    border-radius: var(--radius);
    display: flex; gap: var(--s-5); align-items: center; justify-content: space-between; flex-wrap: wrap;
  }
  .st__softcta p { margin: 0; max-width: 60ch; color: var(--text); }
</style>
