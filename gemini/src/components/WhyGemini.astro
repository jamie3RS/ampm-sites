---
import type { Service } from '~/lib/types';
import Section from '~/components/Section.astro';
interface Props { svc: Service }
const { svc } = Astro.props;
---
<Section id="why">
  <div class="wg__lead">
    <p class="kicker">Why Gemini AMPM</p>
    <h2>Six reasons we keep getting called back</h2>
  </div>

  <div class="wg__pillars">
    {svc.trustPillars.map((p) => (
      <article class="wg__pillar">
        <h3 class="wg__h">{p.title}</h3>
        <p>{p.body}</p>
      </article>
    ))}
  </div>

  <div class="wg__creds">
    <p class="kicker">Accreditations</p>
    <ul class="wg__credlist">
      {svc.accreditationStrip.map((a) => (
        <li>
          <a href={a.href} title={a.longName}>
            {a.thumb
              ? <img src={a.thumb} alt={`${a.shortName} — ${a.longName}`} loading="lazy" width="64" height="64" />
              : <span>{a.shortName}</span>}
          </a>
        </li>
      ))}
    </ul>
  </div>

  <div class="wg__eot">
    <p class="kicker">Employee-Owned Trust</p>
    <p class="wg__eot-body">{svc.eotCallout}</p>
  </div>

  {svc.namedEngineer && (
    <div class="wg__engineer">
      <div class="wg__eng-avatar" aria-hidden="true">{svc.namedEngineer.name.split(' ').map((w) => w[0]).slice(0,2).join('')}</div>
      <div>
        <div class="wg__eng-name">{svc.namedEngineer.name}</div>
        <div class="wg__eng-role">{svc.namedEngineer.role}</div>
        <div class="wg__eng-qual">{svc.namedEngineer.qual}</div>
      </div>
    </div>
  )}
</Section>

<style>
  .wg__lead { max-width: 780px; margin-bottom: var(--s-7); }
  .wg__pillars {
    display: grid; gap: var(--s-5);
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    margin-bottom: var(--s-8);
  }
  .wg__pillar {
    padding: var(--s-5);
    background: var(--bg-elev);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }
  .wg__h { font-size: 1.15rem; margin: 0 0 var(--s-3); color: var(--accent); }
  .wg__pillar p { color: var(--text-soft); margin: 0; }

  .wg__creds { margin-bottom: var(--s-7); }
  .wg__credlist {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-wrap: wrap; gap: var(--s-3);
  }
  .wg__credlist a {
    display: inline-flex; align-items: center; justify-content: center;
    width: 72px; height: 72px; background: #fff; border-radius: 8px; padding: 8px;
  }
  .wg__credlist img { max-width: 100%; max-height: 100%; object-fit: contain; }

  .wg__eot {
    background: var(--accent-soft);
    border-left: 3px solid var(--accent);
    padding: var(--s-5);
    border-radius: 0 var(--radius) var(--radius) 0;
    margin-bottom: var(--s-7);
  }
  .wg__eot-body { color: var(--text); margin: 0; max-width: 75ch; }

  .wg__engineer {
    display: flex; gap: var(--s-4); align-items: center;
    padding: var(--s-5);
    background: var(--bg-elev);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }
  .wg__eng-avatar {
    width: 56px; height: 56px; border-radius: 50%;
    background: linear-gradient(135deg, var(--m-orange), var(--m-purple));
    color: white; font-weight: 800; font-family: var(--f-display);
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 1.2rem;
  }
  .wg__eng-name { font-weight: 700; }
  .wg__eng-role { color: var(--accent); font-size: var(--t-body-s); }
  .wg__eng-qual { color: var(--text-muted); font-size: var(--t-body-s); margin-top: 2px; }
</style>
