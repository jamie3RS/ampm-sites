---
import Base from '~/layouts/Base.astro';
import PageWrap from '~/components/PageWrap.astro';
import PageHero from '~/components/PageHero.astro';
import Kicker from '~/components/Kicker.astro';
---
<Base
  title="Legal — Gemini AMPM"
  description="Privacy, cookies, terms, modern slavery and complaints documents for Gemini AMPM Ltd."
>
  <PageWrap skin="night">
    <PageHero
      kicker="Legal"
      h1="Legal &amp; compliance."
      lede="The published documents you may need for procurement, due diligence or simply to understand how we handle your information."
    />

    <section class="sec tight">
      <div class="sec-index reveal">
        <a class="sec-card" href="/legal/privacy/" style="text-decoration:none;color:inherit;display:block;">
          <h3>Privacy policy</h3>
          <p>How we collect, use, and protect personal information; your rights under UK GDPR.</p>
        </a>
        <a class="sec-card" href="/legal/cookies/" style="text-decoration:none;color:inherit;display:block;">
          <h3>Cookies policy</h3>
          <p>What cookies are set on this site and how to manage them.</p>
        </a>
        <a class="sec-card" href="/legal/terms/" style="text-decoration:none;color:inherit;display:block;">
          <h3>Conditions of Engagement</h3>
          <p>Version 2.0 (March 2026). The terms on which we contract for the supply of fire safety, passive fire, HVAC and M&amp;E compliance services.</p>
        </a>
        <a class="sec-card" href="/legal/modern-slavery/" style="text-decoration:none;color:inherit;display:block;">
          <h3>Modern slavery statement</h3>
          <p>Our commitment under the Modern Slavery Act 2015 and how we manage supply-chain risk.</p>
        </a>
        <a class="sec-card" href="/legal/complaints/" style="text-decoration:none;color:inherit;display:block;">
          <h3>Complaints procedure</h3>
          <p>How to raise a complaint and how we respond.</p>
        </a>
      </div>
    </section>
  </PageWrap>
</Base>
