---
import Base from '~/layouts/Base.astro';
import PageWrap from '~/components/PageWrap.astro';
import PageHero from '~/components/PageHero.astro';
import Kicker from '~/components/Kicker.astro';
import ContactBand from '~/components/ContactBand.astro';
import { TEAM } from '~/data/site';
import type { TeamMember } from '~/data/site';
import { graph, person, breadcrumb } from '~/lib/jsonld';

const groups: { id: TeamMember['tier']; title: string; lede: string }[] = [
  { id: 'group-leadership',       title: 'Group leadership',       lede: 'The three founders.' },
  { id: 'operational-leadership', title: 'Operational leadership', lede: 'The managers who run delivery day-to-day.' },
  { id: 'academy',                title: 'Academy',                lede: 'The apprenticeship cohort.' },
];

const accentVar: Record<TeamMember['accent'], string> = {
  orange: 'var(--m-orange)',
  blue:   'var(--m-blue)',
  green:  'var(--m-green)',
  purple: 'var(--m-purple)',
};

const initials = (m: TeamMember) =>
  m.name.split(' ').map((w) => w[0]).slice(0, 2).join('').toUpperCase();

const schemaJson = graph(
  ...TEAM.map(person),
  breadcrumb([
    { name: 'Home',  href: '/' },
    { name: 'About', href: '/about/' },
    { name: 'Team',  href: '/about/team/' },
  ]),
);
---
<Base
  title="Meet the Team — Jamie Dawson, Luke Finney, Dan Small | Gemini AMPM"
  description="The three founders of Gemini AMPM — all from trades apprenticeships, all part of the EOT. Plus the operational leadership running day-to-day delivery."
  schemaJson={schemaJson}
>
  <PageWrap skin="night">
    <PageHero
      kicker="The team"
      h1="Owned by the people<br />who do the work."
      lede="Three founders, all from trades apprenticeships, who built Gemini AMPM from start-up in 1997 through 27 years of trading to the <strong>Employee Ownership Trust transition in 2024</strong> and on to the formation of AMPM Group. Below them is the operational leadership that runs delivery day-to-day."
    />

    {groups.map((g) => {
      const members = TEAM.filter((m) => m.tier === g.id);
      if (members.length === 0) return null;
      return (
        <section class="sec tight">
          <div class="reveal" style="margin-bottom: 28px">
            <Kicker>{g.title}</Kicker>
            <h2 class="dhead sm">{g.lede}</h2>
          </div>
          <div class="team-grid reveal">
            {members.map((m) => (
              <article class="team-card" id={m.slug}>
                <div class="team-card__photo" style={`background: ${accentVar[m.accent]}`}>
                  {m.photo
                    ? <img src={m.photo} alt={m.name} loading="lazy" />
                    : <span aria-hidden="true">{initials(m)}</span>}
                </div>
                <div class="team-card__body">
                  <h3 class="team-card__name">{m.name}</h3>
                  <p class="team-card__role" set:html={m.role} />
                  {m.ownsLine && (
                    <p class="team-card__owns" set:html={m.ownsLine} />
                  )}
                  <div class="team-card__bio" set:html={m.bio} />
                  {m.linkedin && (
                    <p class="team-card__cta">
                      <a class="btn line sm" href={m.linkedin} target="_blank" rel="noopener noreferrer">{m.name.split(' ')[0]}&rsquo;s LinkedIn ↗</a>
                    </p>
                  )}
                </div>
              </article>
            ))}
          </div>
        </section>
      );
    })}

    <section class="sec tight">
      <div class="intro2 reveal">
        <div>
          <Kicker>The wider team</Kicker>
          <h2 class="dhead sm">More profiles<br />coming soon.</h2>
        </div>
        <div>
          <p class="body">Project directors, service managers, passive-fire and ventilation leads &mdash; the engineers and managers who deliver on site. We&rsquo;re building this page out as people opt in.</p>
          <p class="body" style="margin-top: 16px">
            <a class="btn line sm" href="/contact/">Talk to the team &rarr;</a>
          </p>
        </div>
      </div>
    </section>

    <ContactBand />
  </PageWrap>
</Base>

<style>
  .team-grid { display: grid; grid-template-columns: 1fr; gap: clamp(24px, 3vw, 40px); }
  @media (min-width: 880px) { .team-grid { grid-template-columns: 1fr; } }

  .team-card {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: clamp(20px, 3vw, 36px);
    align-items: start;
    background: rgba(244,234,216,0.03);
    border: 1px solid rgba(244,234,216,0.10);
    border-radius: 6px;
    padding: clamp(20px, 2.5vw, 32px);
    scroll-margin-top: 90px;
  }
  @media (max-width: 720px) {
    .team-card { grid-template-columns: 1fr; }
  }

  .team-card__photo {
    width: 180px; height: 180px;
    border-radius: 4px;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
  }
  @media (max-width: 720px) {
    .team-card__photo { width: 120px; height: 120px; }
  }
  .team-card__photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .team-card__photo span {
    font-family: var(--d-display);
    font-weight: 800;
    font-size: 64px;
    letter-spacing: 0.02em;
    color: #0b0e1c;
  }
  @media (max-width: 720px) {
    .team-card__photo span { font-size: 44px; }
  }

  .team-card__name {
    font-family: var(--d-display);
    font-weight: 800;
    font-size: clamp(26px, 3vw, 34px);
    line-height: 1.05;
    margin: 0 0 4px;
    color: var(--ink, #f4ead8);
  }
  .team-card__role {
    font-family: var(--d-display);
    font-weight: 600;
    font-size: clamp(14px, 1.2vw, 16px);
    text-transform: uppercase;
    letter-spacing: 0.10em;
    color: var(--m-orange);
    margin: 0 0 14px;
  }
  .team-card__owns {
    font-size: 14px;
    color: rgba(244,234,216,0.65);
    margin: 0 0 18px;
    padding-bottom: 16px;
    border-bottom: 1px solid rgba(244,234,216,0.10);
  }
  .team-card__bio :global(p) {
    font-size: 16px;
    line-height: 1.6;
    color: rgba(244,234,216,0.85);
    margin: 0 0 14px;
  }
  .team-card__bio :global(p:last-child) { margin-bottom: 0; }
  .team-card__bio :global(strong) { color: var(--ink, #f4ead8); }
  .team-card__cta { margin-top: 18px; }
</style>
