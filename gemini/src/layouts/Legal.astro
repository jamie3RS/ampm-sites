---
import Base from '~/layouts/Base.astro';
import PageWrap from '~/components/PageWrap.astro';
import PageHero from '~/components/PageHero.astro';
import { graph, breadcrumb } from '~/lib/jsonld';

interface Props {
  title: string;
  kicker: string;
  h1: string;
  lede?: string;
  /** Last reviewed date, shown in the page footer for transparency. */
  lastReviewed: string;
  description?: string;
}

const { title, kicker, h1, lede, lastReviewed, description } = Astro.props;
const schemaJson = graph(breadcrumb([
  { name: 'Home',  href: '/' },
  { name: 'Legal', href: '/legal/' },
  { name: kicker,  href: Astro.url.pathname },
]));
---
<Base title={title} description={description || 'Legal information from Gemini AMPM Ltd.'} schemaJson={schemaJson}>
  <PageWrap skin="night">
    <PageHero kicker={kicker} h1={h1} lede={lede} />

    <div class="legal-body">
      <slot />

      <p class="legal-footer">
        <strong>Last reviewed:</strong> {lastReviewed}.<br />
        <strong>Document owner:</strong> Gemini AMPM Ltd (company number 03437130), Unit 2, Regents Business Centre, Jubilee Road, Burgess Hill, West Sussex RH15 9TL.<br />
        <strong>Contact:</strong> <a href="mailto:info@geminiampm.co.uk">info@geminiampm.co.uk</a> &middot; <a href="tel:+443300430080">0330 043 0080</a>
      </p>
    </div>
  </PageWrap>
</Base>

<style is:global>
  .legal-body { max-width: 760px; margin: 0 auto; padding: 0 24px 80px; }
  .legal-body h2 { font-family: var(--d-display); font-weight: 700;
    font-size: clamp(22px, 2.4vw, 28px); margin: 40px 0 16px;
    color: var(--ink, #f4ead8); line-height: 1.1; }
  .legal-body h3 { font-family: var(--d-display); font-weight: 700;
    font-size: clamp(18px, 1.8vw, 22px); margin: 28px 0 12px;
    color: var(--ink, #f4ead8); }
  .legal-body p { color: var(--ink-2, rgba(244,234,216,0.78));
    font-size: 16px; line-height: 1.65; margin: 0 0 16px; }
  .legal-body p strong { color: var(--ink, #f4ead8); }
  .legal-body ul, .legal-body ol { color: var(--ink-2, rgba(244,234,216,0.78));
    padding-left: 22px; margin: 0 0 18px; }
  .legal-body li { font-size: 16px; line-height: 1.65; margin-bottom: 8px; }
  .legal-body a { color: var(--m-orange); }
  .legal-footer { margin-top: 56px; padding-top: 24px;
    border-top: 1px solid rgba(244,234,216,0.16);
    font-size: 14px; color: rgba(244,234,216,0.55); line-height: 1.7; }
  .legal-draft-banner { background: rgba(232,116,44,0.12); border: 1px solid rgba(232,116,44,0.4);
    border-radius: 4px; padding: 16px 20px; margin-bottom: 32px;
    color: var(--ink, #f4ead8); font-size: 14px; line-height: 1.55; }
  .legal-draft-banner strong { color: var(--m-orange); }

  /* Version meta strip under H1 — version number + governing law. */
  .legal-version { margin: -8px 0 32px; font-size: 13.5px; color: rgba(244,234,216,0.55);
    text-transform: uppercase; letter-spacing: 0.08em; }
  .legal-version strong { color: var(--ink, #f4ead8); }

  /* Definitions list — clause 1. Two-column on desktop, stacked on phone. */
  .legal-defs { margin: 0 0 24px; padding: 0; display: grid;
    grid-template-columns: minmax(160px, 200px) 1fr; gap: 12px 24px;
    border-top: 1px solid rgba(244,234,216,0.10); padding-top: 16px; }
  .legal-defs dt { font-family: var(--d-display); font-weight: 700; color: var(--ink, #f4ead8);
    font-size: 15px; line-height: 1.4; padding: 6px 0;
    border-bottom: 1px solid rgba(244,234,216,0.06); }
  .legal-defs dd { color: var(--ink-2, rgba(244,234,216,0.78)); font-size: 15px;
    line-height: 1.55; margin: 0; padding: 6px 0;
    border-bottom: 1px solid rgba(244,234,216,0.06); }
  @media (max-width: 640px) {
    .legal-defs { grid-template-columns: 1fr; gap: 4px; }
    .legal-defs dt { padding-top: 14px; border-bottom: 0; }
    .legal-defs dd { padding-top: 0; padding-bottom: 12px; }
  }

  /* Numbered subclause paragraphs — number rendered as inline marker. */
  .legal-body p .clno { display: inline-block; font-weight: 700; color: var(--ink, #f4ead8);
    min-width: 38px; margin-right: 4px; font-variant-numeric: tabular-nums; }

  /* Sub-heading INSIDE a clause (e.g. "Payment Terms", "Pay Less Notices"). */
  .legal-body h4 { font-family: var(--d-display); font-weight: 700;
    font-size: 16px; margin: 24px 0 8px; color: var(--ink, #f4ead8);
    text-transform: uppercase; letter-spacing: 0.04em; }

  /* Document-control summary box — used by signed policy pages (anti-slavery,
     etc.) to surface version/owner/signed-by/review-date at a glance. */
  .legal-doc-control { background: rgba(244,234,216,0.04);
    border: 1px solid rgba(244,234,216,0.10); border-radius: 4px;
    padding: 20px 24px; margin: 0 0 36px; }
  .legal-doc-control dl { display: grid; grid-template-columns: minmax(140px, 180px) 1fr;
    gap: 6px 24px; margin: 0; padding: 0; border: 0; }
  .legal-doc-control dt { font-family: var(--d-display); font-weight: 700;
    color: var(--ink, #f4ead8); font-size: 13px; letter-spacing: 0.04em;
    text-transform: uppercase; padding: 2px 0; border: 0; }
  .legal-doc-control dd { color: var(--ink-2, rgba(244,234,216,0.78));
    font-size: 14.5px; margin: 0; padding: 2px 0; border: 0; }
  @media (max-width: 540px) {
    .legal-doc-control dl { grid-template-columns: 1fr; gap: 2px; }
    .legal-doc-control dt { margin-top: 10px; }
  }

  /* Signed-by block at end of formally signed policies. */
  .legal-signed { background: rgba(244,234,216,0.04);
    border-left: 3px solid var(--m-orange); padding: 16px 20px;
    margin: 24px 0 0; font-style: normal; }
  .legal-signed strong { color: var(--ink, #f4ead8); }

  /* Part A summary — protections table at end. */
  .legal-summary-wrap { margin: 48px 0 8px; padding-top: 32px;
    border-top: 1px solid rgba(244,234,216,0.16); }
  .legal-summary { width: 100%; border-collapse: collapse; font-size: 14.5px; }
  .legal-summary th, .legal-summary td { text-align: left; vertical-align: top;
    padding: 12px 14px 12px 0; border-bottom: 1px solid rgba(244,234,216,0.08); }
  .legal-summary th { font-family: var(--d-display); font-weight: 700;
    color: var(--ink, #f4ead8); white-space: nowrap; width: 28%;
    text-transform: uppercase; letter-spacing: 0.04em; font-size: 12.5px;
    padding-right: 24px; }
  .legal-summary td { color: var(--ink-2, rgba(244,234,216,0.78)); line-height: 1.55; }
  @media (max-width: 640px) {
    .legal-summary th, .legal-summary td { display: block; width: 100%; padding: 6px 0; }
    .legal-summary th { padding-top: 16px; border-bottom: 0; }
    .legal-summary td { padding-bottom: 12px; }
  }
</style>
