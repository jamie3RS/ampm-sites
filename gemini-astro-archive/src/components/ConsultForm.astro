---
interface Props {
  headline: string;
  mailbox: string;
  subjectPrefix: string;
  submitLabel?: string;
}
const { headline, mailbox, subjectPrefix, submitLabel = 'Book my consultation' } = Astro.props;
const subject = encodeURIComponent(`${subjectPrefix} New consultation enquiry`);
const action = `mailto:${mailbox}?subject=${subject}`;
---
<form class="form form--consult" method="post" action={action} enctype="text/plain" id="consult">
  <h3 class="form__h">{headline}</h3>
  <div class="form__grid form__grid--4">
    <label class="field">
      <span>Your name</span>
      <input type="text" name="Name" required autocomplete="name" />
    </label>
    <label class="field">
      <span>Email</span>
      <input type="email" name="Email" required autocomplete="email" />
    </label>
    <label class="field">
      <span>Phone</span>
      <input type="tel" name="Phone" required autocomplete="tel" />
    </label>
    <label class="field field--span">
      <span>What are you protecting? <span class="optional">(optional, 1 line)</span></span>
      <input type="text" name="Brief" placeholder="e.g. small server room in central London" />
    </label>
  </div>
  <div class="form__cta">
    <button type="submit" class="btn btn--primary">{submitLabel}</button>
    <p class="form__promise">30-minute call within 24h. No obligation.</p>
  </div>
</form>

<style>
  .form { background: var(--bg-elev); border: 1px solid var(--line); border-radius: var(--radius-lg); padding: var(--s-6); }
  .form__h { font-family: var(--f-display); font-size: var(--t-display-s); margin: 0 0 var(--s-5); }
  .form__grid { display: grid; gap: var(--s-4); }
  .form__grid--4 { grid-template-columns: repeat(2, 1fr); }
  @media (min-width: 720px) { .form__grid--4 { grid-template-columns: repeat(4, 1fr); } }

  .field { display: flex; flex-direction: column; gap: 6px; }
  .field--span { grid-column: 1 / -1; }
  .field > span { font-size: var(--t-body-s); color: var(--text-soft); font-weight: 500; }
  .field .optional { color: var(--text-muted); font-weight: 400; }
  .field input, .field select, .field textarea {
    background: var(--bg);
    border: 1px solid var(--line-strong);
    border-radius: 8px;
    color: var(--text);
    font: inherit;
    padding: 12px 14px;
    transition: border-color .15s var(--ease), background .15s var(--ease);
  }
  .field input:focus, .field select:focus, .field textarea:focus {
    outline: none; border-color: var(--accent); background: var(--bg-elev-2);
  }
  .form__cta {
    display: flex; align-items: center; gap: var(--s-5); flex-wrap: wrap;
    margin-top: var(--s-5);
  }
  .form__promise { color: var(--text-muted); font-size: var(--t-body-s); margin: 0; }
</style>
