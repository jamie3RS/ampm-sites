---
import type { Service } from '~/lib/types';
import Section from '~/components/Section.astro';
interface Props { svc: Service }
const { svc } = Astro.props;
const subject = encodeURIComponent(`${svc.maintenanceSubjectPrefix} Take-over enquiry`);
const action = `mailto:${svc.maintenanceRoutingMailbox}?subject=${subject}`;
---
<Section id="maintenance" tone="elevated">
  <div class="mh__grid">
    <div class="mh__lead">
      <p class="kicker">Maintenance + compliance</p>
      <h2>{svc.maintenanceHeadline}</h2>
      <p class="lede">{svc.takeOverMessage}</p>
      <p class="mh__reg">{svc.maintenanceRegulatoryAnchor}</p>
      <ul class="mh__incl">
        {svc.contractInclusions.map((i) => <li>{i}</li>)}
      </ul>
    </div>

    <form class="form form--maint" method="post" action={action} enctype="text/plain" id="maintenance">
      <h3 class="form__h">Get a maintenance take-over quote</h3>
      <div class="form__grid">
        <label class="field">
          <span>Your name</span>
          <input type="text" name="Name" required />
        </label>
        <label class="field">
          <span>Email</span>
          <input type="email" name="Email" required />
        </label>
        <label class="field">
          <span>Postcode</span>
          <input type="text" name="Postcode" required />
        </label>
        <label class="field">
          <span>What system do you have? <span class="optional">(optional)</span></span>
          <input type="text" name="System" placeholder="e.g. FM-200 single zone, 2018 install, currently maintained by …" />
        </label>
      </div>
      <div class="form__cta">
        <button type="submit" class="btn btn--primary">Get my take-over quote</button>
        <p class="form__promise">Free transition audit. Cancel with 90 days' notice.</p>
      </div>
    </form>
  </div>
</Section>

<style>
  .mh__grid { display: grid; gap: var(--s-6); grid-template-columns: 1fr; }
  @media (min-width: 880px) { .mh__grid { grid-template-columns: 1fr 1fr; } }
  .mh__lead h2 { max-width: 22ch; }
  .mh__reg { color: var(--text-muted); font-size: var(--t-body-s); }
  .mh__incl {
    list-style: none; padding: 0; margin: var(--s-5) 0 0;
    display: grid; gap: var(--s-3);
  }
  .mh__incl li {
    padding-left: 24px; position: relative;
    color: var(--text-soft); font-size: var(--t-body-s);
  }
  .mh__incl li::before {
    content: ''; position: absolute; left: 0; top: 8px;
    width: 14px; height: 14px; border-radius: 4px;
    background: var(--accent);
  }

  .form { background: var(--bg); border: 1px solid var(--line); border-radius: var(--radius-lg); padding: var(--s-6); }
  .form__h { font-family: var(--f-display); font-size: var(--t-display-s); margin: 0 0 var(--s-5); }
  .form__grid { display: grid; gap: var(--s-4); grid-template-columns: 1fr 1fr; }
  .field { display: flex; flex-direction: column; gap: 6px; }
  .field > span { font-size: var(--t-body-s); color: var(--text-soft); font-weight: 500; }
  .field .optional { color: var(--text-muted); font-weight: 400; }
  .field input {
    background: var(--bg-elev);
    border: 1px solid var(--line-strong);
    border-radius: 8px;
    color: var(--text); font: inherit;
    padding: 12px 14px;
  }
  .field input:focus { outline: none; border-color: var(--accent); }
  .form__cta { display: flex; align-items: center; gap: var(--s-5); flex-wrap: wrap; margin-top: var(--s-5); }
  .form__promise { color: var(--text-muted); font-size: var(--t-body-s); margin: 0; }
</style>
