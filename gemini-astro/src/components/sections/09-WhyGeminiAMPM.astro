---
/**
 * Gemini AMPM — Section 9: Why Gemini AMPM
 *
 * Per SERVICE_VERTICAL_TEMPLATE.md §9:
 *  - Final reassurance for the form-hovering visitor + structurally fixes the
 *    orphan-accreditation-pages problem (each pillar surfaces 3-6 cert logos
 *    linking to /accreditations/{slug}/ — 7 pillars * 3-6 = each of the 17
 *    cert pages gets 3+ inbound links).
 *
 *  - 4-6 trust pillars (concise reasons-to-believe lines).
 *  - Accreditation strip filtered by pillar (3-6 clickable logos).
 *  - EOT (Employee-Ownership Trust) callout — ownership-funding differentiator
 *    that also appears in the Service schema bundle (ownershipFunding=EOT).
 *  - Named senior engineer for this service line: photo + name + qualification,
 *    so the buyer sees a real face before scrolling into FAQ + footer CTA.
 *  - Office locations with postcodes — feeds areaServed / LocalBusiness schema
 *    and surfaces local-SEO entities below the fold.
 *
 * Field names mirror the Payload `services` collection in the spec:
 *   `trustPillars`, `accreditationStrip`, `eotCallout`,
 *   `namedEngineer`, `officeLocations`.
 *
 * Payload `relationship` values arrive denormalised — the page loader resolves
 * `accreditationStrip` (→ accreditations), `namedEngineer` (→ team), and
 * `officeLocations` (→ offices) with depth ≥ 2 before passing them in.
 *
 * No JS island — this is static reassurance content. AccreditationBadge owns
 * its own hover lift; the rest is plain markup + tokens.
 */
import Section from '../primitives/Section.astro';
import Container from '../primitives/Container.astro';
import Heading from '../primitives/Heading.astro';
import Kicker from '../primitives/Kicker.astro';
import Button from '../primitives/Button.astro';
import AccreditationBadge from '../primitives/AccreditationBadge.astro';

/**
 * Resolved Payload `accreditations` row used by the strip.
 * `slug` doubles as /public/certs/thumbs/{slug}.png filename and
 * /accreditations/{slug}/ URL path.
 */
export interface AccreditationRef {
  slug: string;
  label: string;
  /** Optional explicit cert page URL — falls back to `/accreditations/{slug}/`. */
  href?: string;
}

/**
 * Resolved Payload `team` row referenced by `namedEngineer`.
 * Photo width/height are required to keep CLS at 0.
 */
export interface TeamMemberRef {
  name: string;
  /** Role title, e.g. "Senior Fire Engineer". */
  role: string;
  /** Qualifications line, e.g. "FIA Tech Member, BAFE SP203-1". */
  qualification?: string;
  /** Resolved media URL for the headshot. Square crop expected. */
  photoUrl: string;
  photoAlt?: string;
  photoWidth: number;
  photoHeight: number;
  /** Optional short bio — single sentence. Surfaced under the qualification. */
  bio?: string;
}

/**
 * Resolved Payload `offices` row used in the locations list.
 * Postcode powers `areaServed` schema + local-SEO surface.
 */
export interface OfficeRef {
  name: string;            // e.g. "London", "Brentwood"
  addressLine1?: string;
  addressLine2?: string;
  city?: string;
  postcode: string;        // required for local-SEO + schema
  /** Optional DDI for click-to-call inline with the location. */
  ddi?: string;
  /** Optional Google Maps link — usually generated from postcode by the page. */
  mapHref?: string;
}

/**
 * A trust pillar is a one-line reason-to-believe. Kept as a string array in
 * the Payload schema (`trustPillars: [{ pillar: string }]`); we accept both
 * the array-of-objects (raw Payload) and the flat string[] (loader-mapped).
 */
export type TrustPillarItem = string | { pillar: string };

export interface Props {
  // ── Headline / framing ────────────────────────────────────────────────
  /** Optional kicker, e.g. "Why Gemini AMPM" / pillar name. */
  kicker?: string;
  /** H2 — buyer-intent framing, e.g. "Why facilities teams pick Gemini AMPM". */
  headline?: string;
  /** Optional sub-headline for the section. */
  subHeadline?: string;

  // ── Payload fields (Section 9) ────────────────────────────────────────
  /** 4-6 reasons-to-believe. */
  trustPillars: TrustPillarItem[];
  /** 3-6 pillar-filtered accreditations. Renders clickable, links to cert pages. */
  accreditationStrip: AccreditationRef[];
  /** Employee-Ownership Trust callout copy. Plain text/sentence. */
  eotCallout: string;
  /** Senior engineer named for this service line. Optional — if absent we skip the block. */
  namedEngineer?: TeamMemberRef;
  /** Offices we cover from, surfaced with postcodes. */
  officeLocations: OfficeRef[];

  // ── Anchor / CTA wiring ───────────────────────────────────────────────
  /** Anchor id of Form #2 (quote) for the closing CTA. Defaults to "quote-form". */
  quoteFormAnchor?: string;
  /** Label for the closing CTA. Defaults to "Get a free site survey". */
  ctaLabel?: string;

  /** Section anchor id — defaults to "why-gemini" for in-page jumps + schema URLs. */
  id?: string;
  /** Pass-through utility classes for layout tweaks. */
  class?: string;
}

const {
  kicker = 'Why Gemini AMPM',
  headline = 'Built for buyers who need the job done properly',
  subHeadline,
  trustPillars,
  accreditationStrip,
  eotCallout,
  namedEngineer,
  officeLocations,
  quoteFormAnchor = 'quote-form',
  ctaLabel = 'Get a free site survey',
  id = 'why-gemini',
  class: className = '',
} = Astro.props;

// Normalise trustPillars — Payload's array-of-objects shape uses `.pillar`,
// but the loader sometimes maps to a flat string[]. Tolerate both so the
// caller doesn't need pre-processing boilerplate.
const pillarList: string[] = trustPillars.map((p) =>
  typeof p === 'string' ? p : p.pillar
);

// Build a resolved href for each accreditation. Default points to the cert
// page that lives at /accreditations/{slug}/ — this is the orphan-page fix
// the spec relies on; do NOT drop the link silently when href is absent.
const accreditationLinks = accreditationStrip.map((a) => ({
  ...a,
  href: a.href ?? `/accreditations/${a.slug}/`,
}));

// Engineer photo alt fallback — keep under 125 chars per the brief.
const engineerAlt =
  namedEngineer?.photoAlt ??
  (namedEngineer
    ? `${namedEngineer.name}, ${namedEngineer.role} at Gemini AMPM`
    : '');

// Office maps href fallback — postcode is the strongest local-SEO signal so
// we always have something to link to even if the page didn't pre-build mapHref.
const officeRows = officeLocations.map((o) => ({
  ...o,
  mapHref:
    o.mapHref ??
    `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(
      [o.addressLine1, o.city, o.postcode].filter(Boolean).join(', ')
    )}`,
  telDigits: o.ddi ? o.ddi.replace(/[^\d+]/g, '') : undefined,
}));
---

<Section
  id={id}
  background="surface-1"
  density="standard"
  class={`why-gemini ${className}`}
>
  <Container variant="default">
    {/* ── Section header ────────────────────────────────────────── */}
    <header class="why-gemini__header">
      <Kicker as="p" tone="accent">{kicker}</Kicker>
      <Heading as="h2" size="lg" class="why-gemini__h2">
        {headline}
      </Heading>
      {subHeadline && <p class="why-gemini__lede">{subHeadline}</p>}
    </header>

    {/* ── Trust pillars (4-6 reasons-to-believe) ────────────────── */}
    {pillarList.length > 0 && (
      <ul
        class="why-gemini__pillars"
        data-count={pillarList.length}
        aria-label="Reasons facilities teams pick Gemini AMPM"
      >
        {pillarList.map((line) => (
          <li class="why-gemini__pillar">
            <span class="why-gemini__pillar-mark" aria-hidden="true">
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                focusable="false"
              >
                <polyline points="20 6 9 17 4 12" />
              </svg>
            </span>
            <span class="why-gemini__pillar-text">{line}</span>
          </li>
        ))}
      </ul>
    )}

    {/* ── EOT callout ───────────────────────────────────────────── */}
    <aside class="why-gemini__eot" aria-label="Employee ownership">
      <div class="why-gemini__eot-badge" aria-hidden="true">EOT</div>
      <div class="why-gemini__eot-body">
        <p class="why-gemini__eot-title">Employee-owned since the team took over.</p>
        <p class="why-gemini__eot-copy">{eotCallout}</p>
      </div>
    </aside>

    {/* ── Accreditation strip (clickable — orphan-page fix) ─────── */}
    {accreditationLinks.length > 0 && (
      <section
        class="why-gemini__accreds"
        aria-labelledby={`${id}-accreds-heading`}
      >
        <h3 id={`${id}-accreds-heading`} class="why-gemini__strip-heading">
          Accredited where it matters
        </h3>
        <ul class="why-gemini__accred-strip">
          {accreditationLinks.map((a) => (
            <li class="why-gemini__accred-item">
              <AccreditationBadge
                slug={a.slug}
                label={a.label}
                href={a.href}
                size="lg"
              />
            </li>
          ))}
        </ul>
      </section>
    )}

    {/* ── Named engineer + offices, side-by-side on desktop ─────── */}
    <div class="why-gemini__people-grid">
      {namedEngineer && (
        <section
          class="why-gemini__engineer"
          aria-labelledby={`${id}-engineer-heading`}
        >
          <h3 id={`${id}-engineer-heading`} class="why-gemini__strip-heading">
            Your senior engineer on this line
          </h3>
          <figure class="why-gemini__engineer-card">
            <img
              src={namedEngineer.photoUrl}
              alt={engineerAlt}
              width={namedEngineer.photoWidth}
              height={namedEngineer.photoHeight}
              loading="lazy"
              decoding="async"
              class="why-gemini__engineer-photo"
            />
            <figcaption class="why-gemini__engineer-meta">
              <p class="why-gemini__engineer-name">{namedEngineer.name}</p>
              <p class="why-gemini__engineer-role">{namedEngineer.role}</p>
              {namedEngineer.qualification && (
                <p class="why-gemini__engineer-qual">
                  {namedEngineer.qualification}
                </p>
              )}
              {namedEngineer.bio && (
                <p class="why-gemini__engineer-bio">{namedEngineer.bio}</p>
              )}
            </figcaption>
          </figure>
        </section>
      )}

      {officeRows.length > 0 && (
        <section
          class="why-gemini__offices"
          aria-labelledby={`${id}-offices-heading`}
        >
          <h3 id={`${id}-offices-heading`} class="why-gemini__strip-heading">
            Where we cover from
          </h3>
          <ul class="why-gemini__office-list">
            {officeRows.map((o) => (
              <li class="why-gemini__office-row">
                <div class="why-gemini__office-name">{o.name}</div>
                <address class="why-gemini__office-address">
                  {o.addressLine1 && <span>{o.addressLine1}</span>}
                  {o.addressLine2 && <span>{o.addressLine2}</span>}
                  {o.city && <span>{o.city}</span>}
                  <span class="why-gemini__office-postcode">
                    {o.postcode}
                  </span>
                </address>
                <div class="why-gemini__office-links">
                  {o.telDigits && o.ddi && (
                    <a
                      href={`tel:${o.telDigits}`}
                      class="why-gemini__office-tel"
                      aria-label={`Call our ${o.name} office on ${o.ddi}`}
                    >
                      {o.ddi}
                    </a>
                  )}
                  <a
                    href={o.mapHref}
                    target="_blank"
                    rel="noopener"
                    class="why-gemini__office-map"
                  >
                    View on map
                  </a>
                </div>
              </li>
            ))}
          </ul>
        </section>
      )}
    </div>

    {/* ── Closing CTA — anchor-jumps up to Form #2 (quote) ─────── */}
    <div class="why-gemini__cta">
      <Button
        variant="primary"
        size="lg"
        href={`#${quoteFormAnchor}`}
        label={ctaLabel}
        data-cta="why-gemini-primary"
      />
    </div>
  </Container>
</Section>

<style>
  /* ── Section rhythm ────────────────────────────────────────────
     Stacked blocks separated by --s-7. Header is tight; pillars,
     EOT, accreditations, people-grid, and CTA all share the same
     vertical step so the rhythm reads as one column. */
  .why-gemini__header {
    max-width: 64ch;
    margin-bottom: var(--s-6, 32px);
  }

  .why-gemini__h2 {
    margin: var(--s-2, 8px) 0 var(--s-3, 12px);
  }

  .why-gemini__lede {
    margin: 0;
    font-family: var(--f-body);
    font-size: var(--t-body-l, 1.125rem);
    line-height: 1.5;
    color: var(--text-soft, var(--ink-2));
    text-wrap: pretty;
  }

  /* ── Trust pillars grid ────────────────────────────────────────
     2-column on tablet+, 3-column on wide desktops when 6 items
     are present. Single column on mobile for thumb-reach legibility. */
  .why-gemini__pillars {
    list-style: none;
    margin: 0 0 var(--s-7, 40px);
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-4, 16px) var(--s-5, 24px);
  }

  @media (min-width: 720px) {
    .why-gemini__pillars {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1080px) {
    .why-gemini__pillars[data-count="5"],
    .why-gemini__pillars[data-count="6"] {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .why-gemini__pillar {
    display: flex;
    align-items: flex-start;
    gap: var(--s-3, 12px);
    font-family: var(--f-body);
    font-size: var(--t-body, 1rem);
    line-height: 1.45;
    color: var(--text, var(--ink));
  }

  .why-gemini__pillar-mark {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 18%, transparent);
    color: var(--accent);
    margin-top: 1px;
  }

  .why-gemini__pillar-text {
    text-wrap: pretty;
  }

  /* ── EOT callout ───────────────────────────────────────────────
     Single-band card with a chunky "EOT" mark on the left. Tinted
     accent wash so it reads as a callout without competing with
     the section background. */
  .why-gemini__eot {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--s-4, 16px);
    align-items: center;

    margin-bottom: var(--s-7, 40px);
    padding: var(--s-5, 24px) var(--s-6, 28px);
    border: 1px solid var(--line-strong, rgba(255, 255, 255, 0.16));
    border-radius: var(--radius, 12px);
    background:
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--accent) 10%, transparent) 0%,
        transparent 65%
      ),
      var(--paper-card, var(--paper-2));
  }

  .why-gemini__eot-badge {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    border-radius: var(--radius, 12px);
    background: var(--accent);
    color: #1a0e00;
    font-family: var(--f-display, "Big Shoulders Display", sans-serif);
    font-weight: 800;
    font-size: 1.25rem;
    letter-spacing: 0.06em;
  }

  .why-gemini__eot-title {
    margin: 0 0 var(--s-1, 4px);
    font-family: var(--f-display);
    font-weight: 700;
    font-size: var(--t-body-l, 1.125rem);
    color: var(--ink);
  }

  .why-gemini__eot-copy {
    margin: 0;
    font-family: var(--f-body);
    font-size: var(--t-body, 1rem);
    line-height: 1.5;
    color: var(--text-soft, var(--ink-2));
    text-wrap: pretty;
  }

  /* ── Accreditation strip ───────────────────────────────────────
     Clickable badges, lg size (80px chip). Justified inline so a
     short pillar's 3 logos sit comfortably, while a long pillar's
     6 logos can wrap to two rows on tablet without crowding. */
  .why-gemini__accreds {
    margin-bottom: var(--s-7, 40px);
  }

  .why-gemini__strip-heading {
    margin: 0 0 var(--s-4, 16px);
    font-family: var(--f-display);
    font-weight: 700;
    font-size: var(--t-h4, 1.25rem);
    color: var(--ink);
    letter-spacing: -0.01em;
  }

  .why-gemini__accred-strip {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    gap: var(--s-5, 24px) var(--s-6, 28px);
  }

  .why-gemini__accred-item {
    /* Each AccreditationBadge owns its own width — we just provide
       the flex gap rhythm. */
    display: inline-flex;
  }

  /* ── People grid: named engineer + office locations ──────────── */
  .why-gemini__people-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-7, 40px);
    margin-bottom: var(--s-7, 40px);
  }

  @media (min-width: 880px) {
    .why-gemini__people-grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
      gap: var(--s-7, 48px);
      align-items: start;
    }
  }

  /* ── Named engineer card ─────────────────────────────────────── */
  .why-gemini__engineer-card {
    display: flex;
    gap: var(--s-4, 20px);
    align-items: flex-start;
    margin: 0;
    padding: var(--s-4, 20px);
    border: 1px solid var(--line, rgba(255, 255, 255, 0.1));
    border-radius: var(--radius, 12px);
    background: var(--paper-card, var(--paper-2));
  }

  .why-gemini__engineer-photo {
    flex: 0 0 auto;
    width: 96px;
    height: 96px;
    border-radius: var(--radius, 12px);
    object-fit: cover;
    background: var(--paper-2, var(--surface));
  }

  .why-gemini__engineer-meta {
    margin: 0;
    font-family: var(--f-body);
  }

  .why-gemini__engineer-name {
    margin: 0 0 var(--s-1, 4px);
    font-family: var(--f-display);
    font-weight: 700;
    font-size: var(--t-body-l, 1.125rem);
    color: var(--ink);
    letter-spacing: -0.01em;
  }

  .why-gemini__engineer-role {
    margin: 0 0 var(--s-2, 8px);
    font-size: var(--t-body, 1rem);
    color: var(--accent);
    font-weight: 600;
  }

  .why-gemini__engineer-qual {
    margin: 0 0 var(--s-2, 8px);
    font-size: var(--t-body-s, 0.875rem);
    color: var(--text-soft, var(--ink-2));
    letter-spacing: 0.02em;
  }

  .why-gemini__engineer-bio {
    margin: 0;
    font-size: var(--t-body-s, 0.875rem);
    line-height: 1.5;
    color: var(--text-soft, var(--ink-2));
    text-wrap: pretty;
  }

  /* ── Office locations list ───────────────────────────────────── */
  .why-gemini__office-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-3, 12px);
  }

  @media (min-width: 560px) {
    .why-gemini__office-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .why-gemini__office-row {
    display: flex;
    flex-direction: column;
    gap: var(--s-1, 4px);
    padding: var(--s-4, 16px);
    border: 1px solid var(--line, rgba(255, 255, 255, 0.1));
    border-radius: var(--radius, 12px);
    background: var(--paper-card, var(--paper-2));
  }

  .why-gemini__office-name {
    font-family: var(--f-display);
    font-weight: 700;
    font-size: var(--t-body-l, 1.125rem);
    color: var(--ink);
    letter-spacing: -0.01em;
  }

  .why-gemini__office-address {
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-style: normal;
    font-family: var(--f-body);
    font-size: var(--t-body-s, 0.875rem);
    line-height: 1.4;
    color: var(--text-soft, var(--ink-2));
  }

  .why-gemini__office-postcode {
    font-weight: 600;
    color: var(--text, var(--ink));
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .why-gemini__office-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-3, 12px);
    margin-top: var(--s-2, 8px);
    font-family: var(--f-body);
    font-size: var(--t-body-s, 0.875rem);
  }

  .why-gemini__office-tel,
  .why-gemini__office-map {
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
  }

  .why-gemini__office-tel:hover,
  .why-gemini__office-map:hover,
  .why-gemini__office-tel:focus-visible,
  .why-gemini__office-map:focus-visible {
    text-decoration: underline;
  }

  /* ── Closing CTA ─────────────────────────────────────────────── */
  .why-gemini__cta {
    display: flex;
    justify-content: flex-start;
  }

  /* ── Day-skin overrides ──────────────────────────────────────── */
  :global(html[data-skin="day"]) .why-gemini__eot {
    border-color: rgba(28, 24, 18, 0.12);
  }

  :global(html[data-skin="day"]) .why-gemini__engineer-card,
  :global(html[data-skin="day"]) .why-gemini__office-row {
    border-color: rgba(28, 24, 18, 0.1);
  }
</style>
