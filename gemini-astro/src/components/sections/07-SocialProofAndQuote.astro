<script>
  /**
   * Form #2 — Astro Action submission with redirect on success.
   *
   * We progressively enhance the native POST to call the Astro Action via
   * fetch so we can client-side-redirect to /thanks/{pillar}/ (per spec).
   * If JS fails or is disabled, the form falls back to a server-side
   * POST to /_actions/quote which Astro handles and redirects from.
   */
  const forms = document.querySelectorAll<HTMLFormElement>(
    '.sec-proof-quote__form',
  );

  for (const form of Array.from(forms)) {
    form.addEventListener('submit', async (event) => {
      // Native validation must pass before we hijack the submit.
      if (!form.checkValidity()) {
        return; // browser will show its own error UI
      }
      event.preventDefault();

      const thanksPath = form.dataset.thanksPath ?? '/thanks/';
      const submitBtn = form.querySelector<HTMLButtonElement>(
        'button[type="submit"]',
      );
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.setAttribute('aria-busy', 'true');
      }

      try {
        const formData = new FormData(form);
        const res = await fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: { Accept: 'application/json' },
        });

        if (!res.ok) {
          // Re-enable + let the user retry; an inline error message
          // hook can be added by the parent page if needed.
          throw new Error(`Submission failed (${res.status})`);
        }

        // Astro Action JSON includes `thanksPath` per the spec — prefer
        // that over the data-attribute fallback.
        let target = thanksPath;
        try {
          const data = (await res.clone().json()) as { thanksPath?: string };
          if (data?.thanksPath) target = data.thanksPath;
        } catch {
          // Action returned non-JSON (e.g. a redirect already followed) —
          // honour the data-thanks-path fallback.
        }

        window.location.assign(target);
      } catch (err) {
        // Re-enable submit so the user can retry. The D1 mirror in the
        // Action handler means any successful network call already
        // captured the lead even if the UI thinks it failed.
        console.error('[quote-form]', err);
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.removeAttribute('aria-busy');
        }
      }
    });
  }
</script>
