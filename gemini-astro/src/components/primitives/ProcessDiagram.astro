---
/**
 * Gemini AMPM — <ProcessDiagram> primitive.
 *
 * Section 5 of the service-vertical template ("How It Works"): a 4-step
 * buying-process diagram that maps Survey → Design & Quote → Install →
 * Commission/Handover. Earns HowTo schema where applicable (schema is
 * emitted by the schema bundle generator at page level, not here).
 *
 * Layout:
 *   - Desktop (>= 768px): 4-column horizontal grid with a thin meridian
 *     rail connecting the step badges. Pure CSS — no JS.
 *   - Mobile: vertical timeline. Connector rail runs down the left
 *     gutter behind the numbered badges. Each step stacks as a card-ish
 *     block with the title, body, deliverable chip and indicative timing.
 *
 * Colour & spacing are token-driven (--g-accent, --paper-2, --pad-x,
 * --s-*), so the diagram re-themes automatically when the parent flips
 * per-pillar accent or skin. No Tailwind colour utilities — Tailwind is
 * used only for layout (grid, gap, flex).
 *
 * Icons are referenced by slug only — the SVG sprite is rendered via
 * <use href="#icon-{slug}"> against the project sprite (mounted in
 * BaseLayout). If a slug is unknown the badge falls back to the step
 * number, so the component never breaks on missing assets.
 *
 * Accessibility:
 *   - Renders as an <ol> so screen readers announce step order.
 *   - The visual connector rail is decorative (aria-hidden).
 *   - Each step's number badge has aria-hidden + sr-only "Step N" text
 *     so AT users hear "Step 2, Design & quote, ..." not "two, design...".
 *   - Deliverable & timing rows use definition-list semantics to make
 *     the relationship explicit.
 *
 * Spec: SERVICE_VERTICAL_TEMPLATE.md §Section 5 — 4 steps, each 40-80
 * words of body copy plus a named deliverable + indicative timing.
 */

import Heading from './Heading.astro';

export interface ProcessStep {
  /** Step title — e.g. "Survey", "Design & quote". Rendered as H3. */
  h3: string;
  /** 40-80 words explaining what happens in this step. */
  bodyCopy: string;
  /** Concrete artefact the buyer receives at end of step. */
  deliverable: string;
  /** Human-readable timing — "Within 48h", "5 working days", etc. */
  indicativeTiming: string;
  /** Sprite slug (without `icon-` prefix). Falls back to step number. */
  iconSlug?: string;
}

interface Props {
  /** Exactly 4 steps per the template spec. */
  steps: ProcessStep[];
  /** Optional id for anchor-jump from the hero "See how it works" CTA. */
  id?: string;
  /** Extra classes — Tailwind utilities for outer spacing if ever needed. */
  class?: string;
}

const { steps, id, class: extraClass } = Astro.props;

/* Defensive: the template expects exactly 4 steps, but we don't want
 * to throw at build — Payload editors will get a CMS-level validation
 * for this. We just render what we're given. */
if (import.meta.env.DEV && steps.length !== 4) {
  // eslint-disable-next-line no-console
  console.warn(
    `[ProcessDiagram] expected 4 steps per SERVICE_VERTICAL_TEMPLATE §5, got ${steps.length}.`,
  );
}
---

<ol
  id={id}
  class:list={['process-diagram', extraClass]}
  aria-label="Our 4-step process from survey to handover"
>
  {steps.map((step, i) => {
    const stepNumber = i + 1;
    const isLast = i === steps.length - 1;
    return (
      <li class="process-diagram__step" data-step={stepNumber}>
        {/* Connector rail — decorative; drawn between badges, not after
            the last step. Desktop = horizontal segment to the right of
            the badge; mobile = vertical segment below it. */}
        {!isLast && (
          <span class="process-diagram__rail" aria-hidden="true"></span>
        )}

        <div class="process-diagram__badge" aria-hidden="true">
          {step.iconSlug ? (
            <svg
              class="process-diagram__icon"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              focusable="false"
            >
              <use href={`#icon-${step.iconSlug}`}></use>
            </svg>
          ) : (
            <span class="process-diagram__number">{stepNumber}</span>
          )}
        </div>

        <span class="sr-only">Step {stepNumber}.</span>

        <div class="process-diagram__body">
          <Heading as="h3" size="sm" class="process-diagram__title">
            {step.h3}
          </Heading>

          <p class="process-diagram__copy">{step.bodyCopy}</p>

          <dl class="process-diagram__meta">
            <div class="process-diagram__meta-row">
              <dt>You get</dt>
              <dd>{step.deliverable}</dd>
            </div>
            <div class="process-diagram__meta-row">
              <dt>Timing</dt>
              <dd>{step.indicativeTiming}</dd>
            </div>
          </dl>
        </div>
      </li>
    );
  })}
</ol>

<style>
  /* ── Outer list ────────────────────────────────────────────────
     Mobile-first: stacked vertical timeline. The connector rail is
     drawn per-step (see __rail below) rather than on the <ol> itself
     because the last step must not have a tail. */
  .process-diagram {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--s-7, 48px);
  }

  /* ── Per-step ─────────────────────────────────────────────────
     Mobile layout: badge in the left gutter, body to its right.
     The badge column is wide enough to host the connector rail
     without it colliding with the body copy. */
  .process-diagram__step {
    position: relative;
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: var(--s-4, 16px);
    align-items: start;
  }

  .process-diagram__step::before {
    /* Removes any default list marker from the <li>. */
    content: none;
  }

  /* ── Badge ────────────────────────────────────────────────────
     Circular, accent-tinted, fixed size so the connector rail
     anchors to a known centre point. Per-pillar accent reads
     through --g-accent — flips automatically when the page sets
     a different pillar token. */
  .process-diagram__badge {
    grid-column: 1;
    width: 48px;
    height: 48px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--g-accent, var(--accent)) 18%, transparent);
    border: 1px solid color-mix(in srgb, var(--g-accent, var(--accent)) 45%, transparent);
    color: var(--g-accent, var(--accent));
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--f-display, "Big Shoulders Display", sans-serif);
    font-weight: 700;
    font-size: 1.25rem;
    line-height: 1;
    position: relative;
    z-index: 1; /* Sits above the rail. */
    flex-shrink: 0;
  }

  .process-diagram__icon {
    width: 24px;
    height: 24px;
    fill: currentColor;
  }

  .process-diagram__number {
    /* Visual-only — sr-only "Step N" carries the semantics. */
    font-variant-numeric: tabular-nums;
  }

  /* ── Connector rail ──────────────────────────────────────────
     Mobile: vertical 1px line from below the badge down to the
     next step's badge. We anchor it to the badge column so it
     stays aligned even if body copy heights differ.
     The rail tints with --g-accent at low opacity so it reads as
     a guide rather than a structural divider. */
  .process-diagram__rail {
    position: absolute;
    left: calc(48px / 2 - 1px); /* centre of the 48px badge column */
    top: 48px; /* start just under the badge */
    width: 2px;
    height: calc(100% + var(--s-7, 48px) - 48px);
    background: linear-gradient(
      to bottom,
      color-mix(in srgb, var(--g-accent, var(--accent)) 35%, transparent),
      color-mix(in srgb, var(--g-accent, var(--accent)) 8%, transparent)
    );
    z-index: 0;
    pointer-events: none;
  }

  /* ── Body block ──────────────────────────────────────────────
     Title + copy + meta list. Sits in column 2 of the per-step
     grid. Max-width keeps line length readable on tablet widths
     before the desktop break kicks in. */
  .process-diagram__body {
    grid-column: 2;
    min-width: 0; /* allow flex/grid children to shrink */
  }

  .process-diagram__title {
    margin-bottom: var(--s-3, 12px);
  }

  .process-diagram__copy {
    margin: 0 0 var(--s-4, 16px);
    color: var(--text-soft, var(--ink-2, currentColor));
    font-size: var(--t-body, 1rem);
    line-height: 1.55;
    max-width: 52ch;
  }

  /* ── Meta (deliverable + timing) ─────────────────────────────
     Definition list with a left-rail border that picks up the
     accent so it visually ties to the badge. Term/desc render on
     one row each at this size to stay scannable. */
  .process-diagram__meta {
    margin: 0;
    padding: var(--s-3, 12px) var(--s-4, 16px);
    background: var(--paper-2, var(--bg-elev, rgba(255,255,255,0.04)));
    border-left: 2px solid color-mix(in srgb, var(--g-accent, var(--accent)) 60%, transparent);
    border-radius: 0 var(--radius, 12px) var(--radius, 12px) 0;
    display: grid;
    gap: var(--s-2, 8px);
  }

  .process-diagram__meta-row {
    display: grid;
    grid-template-columns: 5.5rem 1fr;
    gap: var(--s-3, 12px);
    align-items: baseline;
  }

  .process-diagram__meta-row dt {
    font-family: var(--f-body, "Archivo", sans-serif);
    font-size: var(--t-kicker, 0.75rem);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted, var(--ink-3, currentColor));
    margin: 0;
  }

  .process-diagram__meta-row dd {
    margin: 0;
    font-size: var(--t-body-s, 0.875rem);
    color: var(--text, var(--ink, currentColor));
    line-height: 1.45;
  }

  /* ── sr-only (local copy; primitives must be self-contained
     and we can't assume base.css's class is available in the
     component's scoped style cascade). */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Desktop: 4-column horizontal layout ─────────────────────
     768px chosen to align with the template's mobile/desktop
     break — below this, the timeline reads better as a vertical
     scroll than a cramped 4-up grid. */
  @media (min-width: 768px) {
    .process-diagram {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: var(--s-5, 24px);
      align-items: start;
    }

    .process-diagram__step {
      /* Each step becomes a vertical card-ish stack: badge on top,
         then body below. The 1fr column from mobile collapses. */
      grid-template-columns: 1fr;
      gap: var(--s-4, 16px);
      padding-top: 0;
    }

    .process-diagram__badge {
      grid-column: 1;
      /* Allow the rail to pass *through* the badge centre by
         keeping z-index above it. */
    }

    .process-diagram__body {
      grid-column: 1;
    }

    /* Horizontal rail — runs from the right edge of this badge
       to the left edge of the next step's badge. Positioned at
       the badge's vertical centre (24px = badge radius). */
    .process-diagram__rail {
      left: 48px; /* right edge of the badge */
      top: 23px;  /* vertical centre of 48px badge minus 1px */
      width: calc(100% - 48px + var(--s-5, 24px));
      height: 2px;
      background: linear-gradient(
        to right,
        color-mix(in srgb, var(--g-accent, var(--accent)) 35%, transparent),
        color-mix(in srgb, var(--g-accent, var(--accent)) 8%, transparent)
      );
    }

    .process-diagram__copy {
      max-width: none; /* let the 1/4 column govern line length */
    }

    .process-diagram__meta-row {
      /* Tighter columns inside the narrower desktop card. */
      grid-template-columns: 4.5rem 1fr;
    }
  }

  /* Respect reduced-motion: nothing animates here today, but if
     we later add a step-reveal observer it should opt out by
     default rather than per-instance. */
  @media (prefers-reduced-motion: reduce) {
    .process-diagram__rail {
      transition: none;
    }
  }
</style>
