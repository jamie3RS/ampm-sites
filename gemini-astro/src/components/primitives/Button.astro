---
/**
 * Gemini AMPM — Button primitive.
 *
 * CTA button with three variants:
 *  - primary : amber-on-deep-navy, the dominant page CTA
 *  - secondary: hairline outline on the night skin (mirrors .btn--line)
 *  - ghost   : transparent, underline-on-hover, used inline in prose
 *
 * Honours the prototype's brand tokens (see _websites/gemini/src/styles/tokens.css
 * and base.css). Big Shoulders Display for the label, 0.04em tracking, uppercase.
 *
 * `tel:` hrefs auto-render a phone glyph and tighten the gap so the number sits
 * snug against the icon — picks up the day-arc accent on hover via --accent.
 *
 * Renders <a> when href is provided, otherwise <button type="button">. Extra
 * Astro attributes (aria-*, data-*, target, rel, type, etc.) pass straight
 * through via ...rest, so callers can wire it to forms or external links
 * without wrapping it.
 */
import type { HTMLAttributes } from 'astro/types';

type Variant = 'primary' | 'secondary' | 'ghost';
type Size = 'sm' | 'md' | 'lg';

type Anchor = Omit<HTMLAttributes<'a'>, 'href'>;
type Btn    = HTMLAttributes<'button'>;

interface Props extends Anchor, Btn {
  variant?: Variant;
  size?: Size;
  href?: string;
  label: string;
  /** Render an explicit element. Defaults to <a> when href is set, else <button>. */
  as?: 'a' | 'button';
}

const {
  variant = 'primary',
  size = 'md',
  href,
  label,
  as,
  class: className,
  ...rest
} = Astro.props;

const Tag = as ?? (href ? 'a' : 'button');
const isTel = typeof href === 'string' && href.startsWith('tel:');

const classes = [
  'g-btn',
  `g-btn--${variant}`,
  `g-btn--${size}`,
  isTel ? 'g-btn--tel' : null,
  className,
]
  .filter(Boolean)
  .join(' ');

// When rendering a <button>, default the type to "button" so it doesn't
// accidentally submit forms it gets dropped into.
const buttonType =
  Tag === 'button' ? ((rest as Btn).type ?? 'button') : undefined;
---
<Tag
  class={classes}
  href={Tag === 'a' ? href : undefined}
  type={buttonType}
  {...rest}
>
  {isTel && (
    <svg
      class="g-btn__icon"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      focusable="false"
    >
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92Z" />
    </svg>
  )}
  <span class="g-btn__label">{label}</span>
</Tag>

<style>
  .g-btn {
    --g-btn-bg: var(--accent);
    --g-btn-fg: #1a0e00;
    --g-btn-bg-hover: #f08233;
    --g-btn-border: var(--accent);

    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--s-2);

    padding: 14px 22px;
    border: 1px solid var(--g-btn-border);
    border-radius: var(--radius);
    background: var(--g-btn-bg);
    color: var(--g-btn-fg);

    font-family: var(--f-display);
    font-weight: 700;
    font-size: var(--t-body);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    line-height: 1;

    cursor: pointer;
    user-select: none;
    transition:
      transform 0.15s var(--ease),
      background 0.15s var(--ease),
      border-color 0.15s var(--ease),
      color 0.15s var(--ease);
  }

  .g-btn:hover {
    transform: translateY(-1px);
    background: var(--g-btn-bg-hover);
    color: var(--g-btn-fg);
    text-decoration: none;
  }

  .g-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .g-btn:disabled,
  .g-btn[aria-disabled='true'] {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }

  /* ── Variants ───────────────────────────────────────────── */

  .g-btn--primary {
    --g-btn-bg: var(--accent);
    --g-btn-fg: #1a0e00;
    --g-btn-bg-hover: #f08233;
    --g-btn-border: var(--accent);
  }

  .g-btn--secondary {
    --g-btn-bg: transparent;
    --g-btn-fg: var(--text);
    --g-btn-bg-hover: transparent;
    --g-btn-border: var(--line-strong);
  }
  .g-btn--secondary:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .g-btn--ghost {
    --g-btn-bg: transparent;
    --g-btn-fg: var(--text);
    --g-btn-bg-hover: transparent;
    --g-btn-border: transparent;
    padding-inline: var(--s-3);
  }
  .g-btn--ghost:hover {
    color: var(--accent);
    background: var(--accent-soft);
  }

  /* ── Sizes ──────────────────────────────────────────────── */

  .g-btn--sm {
    padding: 10px 16px;
    font-size: var(--t-body-s);
  }

  .g-btn--md {
    /* default — declared explicitly so it overrides cascading utility classes */
    padding: 14px 22px;
    font-size: var(--t-body);
  }

  .g-btn--lg {
    padding: 18px 28px;
    font-size: var(--t-body-l);
  }

  /* ── Tel modifier ───────────────────────────────────────── */

  .g-btn--tel {
    /* Phone numbers read as numerals — drop the all-caps treatment so digits
       sit on the baseline cleanly. */
    text-transform: none;
    letter-spacing: 0.02em;
    font-variant-numeric: tabular-nums;
  }

  .g-btn__icon {
    flex: 0 0 auto;
    width: 1em;
    height: 1em;
  }

  .g-btn__label {
    display: inline-block;
  }
</style>
